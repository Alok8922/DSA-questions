class Solution {
public:
    int minSubArrayLen(int target, vector<int>& nums) {
        int n=nums.size();
        int total=INT_MAX;
        int i=0,j=0;
        int sum=0;
        while(j<n){
            sum+=nums[j];
            while(sum>=target){
                total=min(total,j-i+1);
                sum-=nums[i];
               i++;
            }
            j++;
        }
        return (total==INT_MAX)?0:total;
    }
};
