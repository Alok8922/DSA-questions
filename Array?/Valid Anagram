class Solution {
  public:
    bool areAnagrams(string& s1, string& s2) {
        // code here
        if(s1.size()!=s2.size())
        return 0;
        vector<int>freq(26,0);
        for(int i=0;i<s1.size();i++){
            freq[s1[i]-'a']++;
        }
        for(int i=0;i<s2.size();i++){
            freq[s2[i]-'a']--;
        }
        for(int i=0;i<freq.size();i++){
            if(freq[i]!=0)
            return 0;
        }
        return 1;
    }
};
